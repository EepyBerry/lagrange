{
  "name": "lagrange",
  "version": "0.5.2-SNAPSHOT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-host": "vite --host",
    "build": "run-p type-check format \"build-only {@}\" --",
    "preview": "vite preview",
    "preview-host": "vite preview --host",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EepyBerry/lagrange.git"
  },
  "keywords": [
    "vue",
    "vuejs",
    "typescript",
    "threejs"
  ],
  "author": "EepyBerry",
  "license": "ISTSL-NR 1.0",
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@unhead/vue": "^2.1.12",
    "crypto-hash": "^3.1.0",
    "dexie": "^4.3.0",
    "file-saver": "^2.0.5",
    "iconify-icon": "^2.3.0",
    "jszip": "^3.10.1",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.7",
    "pako": "^2.1.0",
    "seedrandom": "^3.0.5",
    "three": "^0.183.2",
    "vue": "^3.5.30",
    "vue-accessible-color-picker": "^5.3.1",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/file-saver": "^2.0.7",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.0",
    "@types/pako": "^2.0.4",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^16.3.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "~1.57.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^8.0.2",
    "vue-tsc": "^3.2.6"
  }
